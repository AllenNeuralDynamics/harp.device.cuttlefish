	(text "In \"Passthrough Mode\" where the external pins (J13, J14) can drive the state of the\nTTL pins, the corresponding buffers need to accept either 3.3V or 5V power depending\non the logic level of the device connecting to it. This circuit above provides 3.3V\nor 5V power to the buffer pins depending on the switch state and whether the device\nis in \"Passthrough Mode\" in the first place."
		(exclude_from_sim no)
		(at 16.51 184.404 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "d9212a21-644b-43ef-8501-943f985a768a")
	)
	(text " SW/~{EXT} | SW3    | VDDA   | Q4 VGS | Q3 VGS \n   0    |   0    | 3.3V   | -3.3V  |   0V   \n   0    |   1    |  5V    |   0V   |  -5V   \n   1    |   X    | 3.3V   | -3.3V  |   0V  \n\n"
		(exclude_from_sim no)
		(at 60.198 168.148 0)
		(effects
			(font
				(face "Ubuntu Mono")
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "d9dfab81-a87d-4828-a157-015e5d3d3a91")
	)
